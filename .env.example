# ----- Django -----
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=*.railway.app,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://leticia-agent.up.railway.app
LOG_LEVEL=INFO

# ----- Supabase Postgres -----
# Use the "Transaction" pooler URL from Supabase > Project Settings > Database.
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@host:6543/postgres

# ----- Anthropic -----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# ----- Evolution API -----
EVOLUTION_BASE_URL=https://your-evolution-host
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-id
# Random shared secret that Evolution will send back as ?token= or X-Webhook-Token header.
# Rotate this regularly.
EVOLUTION_WEBHOOK_TOKEN=generate-a-random-string

# ----- Slack -----
# Bot token: from Slack app > OAuth & Permissions (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-...
# App-level token: Slack app > Basic Information > App-Level Tokens > scope: connections:write
SLACK_APP_TOKEN=xapp-1-...
SLACK_CHANNEL=#leticia-teste
# Comma-separated Slack user IDs allowed to run commands. Empty = everyone in the channel.
SLACK_ALLOWED_USERS=

# ----- Letícia behavior -----
LETICIA_AUTONOMY_DEFAULT=true
LETICIA_TYPING_DELAY_MIN_MS=2000
LETICIA_TYPING_DELAY_MAX_MS=8000
